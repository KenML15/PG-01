<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="720.0" prefWidth="1100.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainController">
    <top>
        <VBox prefHeight="87.0" prefWidth="600.0" styleClass="header-bar" BorderPane.alignment="CENTER">
            <children>
                <HBox>
                    <children>
                        <Label styleClass="header-badge" text="PG-01" />
                        <VBox>
                            <children>
                                <Label prefHeight="17.0" prefWidth="247.0" styleClass="header-title" text="Recursividad aplicada en JavaFX" />
                                <Label prefHeight="17.0" prefWidth="255.0" styleClass="header-sub" text="IF-3001 Algoritmos y Estructuras de Datos" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
            </children>
        </VBox>
    </top>
    <center>
        <TabPane prefHeight="227.0" prefWidth="600.0" styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE" BorderPane.alignment="CENTER">
            <tabs>
                <Tab text="Fact-Fib">
                    <content>
                        <AnchorPane prefHeight="200.0" prefWidth="200.0">
                            <children>
                                <VBox layoutX="20.0" layoutY="20.0" spacing="15.0">
                                    <children>
                                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                                            <children>
                                                <TextField fx:id="txtN" prefHeight="35.0" prefWidth="150.0" promptText="Valor de n" />
                                                <RadioButton fx:id="rbFactorial" mnemonicParsing="false" selected="true" text="Factorial">
                                                    <toggleGroup>
                                                        <ToggleGroup fx:id="tgTipo" />
                                                    </toggleGroup>
                                                </RadioButton>
                                                <RadioButton fx:id="rbFibonacci" mnemonicParsing="false" text="Fibonacci" toggleGroup="$tgTipo" />
                                            </children>
                                        </HBox>
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnCalcularGeneral" mnemonicParsing="false" onAction="#handleCalcularGeneral" styleClass="btn-primary" text="Calcular" />
                                                <Button fx:id="btnLimpiarGeneral" mnemonicParsing="false" onAction="#handleLimpiarGeneral" styleClass="btn-ghost" text="Limpiar" />
                                            </children>
                                        </HBox>
                                        <VBox spacing="5.0">
                                            <children>
                                                <Label styleClass="param-label" text="Resultado:" />
                                                <Label fx:id="lblResultadoGeneral" styleClass="stat-value" text="--" />
                                                <Label styleClass="param-label" text="Complejidad Estimada:" />
                                                <Label fx:id="lblComplejidadGeneral" styleClass="stat-value-sm" text="--" />
                                            </children>
                                        </VBox>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>
                <Tab text="Factorial">
                    <content>
                        <SplitPane dividerPositions="0.6" prefHeight="200.0" prefWidth="200.0">
                            <items>
                                <VBox styleClass="panel">
                                    <children>
                                        <Label styleClass="panel-title" text="Árbol De Llamadas recursivas" />
                                        <Canvas fx:id="canvasTree" height="500.0" styleClass="tree-canvas" width="600.0" />
                                    </children>
                                </VBox>
                                <VBox styleClass="panel">
                                    <children>
                                        <Label styleClass="action-label" text="Parámetros" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Label styleClass="param-label" text="n=" />
                                                <Label fx:id="lblFactN" styleClass="value-badge" text="5" />
                                            </children>
                                        </HBox>
                                        <Slider fx:id="sliderFactN" max="15" showTickLabels="true" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnFactCalc" mnemonicParsing="false" styleClass="btn-primary" text="Calcular" />
                                                <Button fx:id="btnFactReset" mnemonicParsing="false" styleClass="btn-ghost" text="Limpiar" />
                                            </children>
                                        </HBox>
                                        <GridPane vgap="10.0">
                                            <columnConstraints>
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                                <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                            </columnConstraints>
                                            <rowConstraints>
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                                <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                            </rowConstraints>
                                            <children>
                                                <VBox>
                                                    <children>
                                                        <Label styleClass="stat-label" text="Resultado" />
                                                        <Label fx:id="lblFactResult" styleClass="stat-value" text="--" />
                                                    </children>
                                                </VBox>
                                                <VBox GridPane.rowIndex="1">
                                                    <children>
                                                        <Label styleClass="stat-label" text="Complejidad" />
                                                        <Label fx:id="lblComplexity" styleClass="stat-value-sm" text="--" />
                                                    </children>
                                                </VBox>
                                                <VBox GridPane.columnIndex="1">
                                                    <children>
                                                        <Label styleClass="stat-label" text="Llamadas" />
                                                        <Label fx:id="lblFactCalls" styleClass="stat-value" text="--" />
                                                    </children>
                                                </VBox>
                                            </children>
                                 <padding>
                                    <Insets left="5.0" top="10.0" />
                                 </padding>
                                        </GridPane>
                                        <Label styleClass="section-label" text="Pasos de ejecución" />
                                        <ListView fx:id="listSteps" styleClass="steps-list" VBox.vgrow="ALWAYS" />
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>
                <Tab text="Fibonacci">
                    <content>
                        <SplitPane dividerPositions="0.6" prefHeight="200.0" prefWidth="200.0">
                            <items>
                                <VBox prefHeight="604.0" prefWidth="481.0" styleClass="panel">
                                    <children>
                                        <Label styleClass="panel-title" text="Visualización Árbol Fibonacci" />
                                        <Canvas fx:id="canvasFib" height="500.0" styleClass="tree-canvas" width="527.0" />
                                    </children>
                                </VBox>
                                <VBox spacing="15.0" styleClass="panel">
                                    <children>
                                        <Label styleClass="action-label" text="Parametros" />
                                        <Slider fx:id="sliderFibN" blockIncrement="1.0" majorTickUnit="1.0" max="10.0" showTickLabels="true" showTickMarks="true" />
                                        <HBox spacing="10.0">
                                            <children>
                                                <Button fx:id="btnFibCalc" onAction="#runFibonacciTab" styleClass="btn-primary" text="Calcular">
                                       <HBox.margin>
                                          <Insets left="10.0" />
                                       </HBox.margin></Button>
                                                <Button fx:id="btnFibReset" onAction="#resetFibTab"  styleClass="btn-primary" mnemonicParsing="false" text="Limpiar" />
                                                <RadioButton fx:id="rbMemoOn" selected="true" text="Memoización">
                                       <HBox.margin>
                                          <Insets top="4.0" />
                                       </HBox.margin></RadioButton>
                                            </children>
                                        </HBox>
                                        <Separator />
                              <GridPane vgap="10.0">
                                 <columnConstraints>
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                    <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                                 </columnConstraints>
                                 <rowConstraints>
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                    <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
                                 </rowConstraints>
                                 <children>
                                    <VBox>
                                       <children>
                                          <Label styleClass="stat-label" text="Resultado" />
                                          <Label fx:id="lblFibResult" styleClass="stat-value" text="--" />
                                       </children>
                                       <GridPane.margin>
                                          <Insets left="10.0" />
                                       </GridPane.margin>
                                    </VBox>
                                    <VBox GridPane.rowIndex="1">
                                       <children>
                                          <Label styleClass="stat-label" text="Complejidad" />
                                          <Label fx:id="lblfibComplexity" styleClass="stat-value-sm" text="--" />
                                       </children>
                                       <GridPane.margin>
                                          <Insets left="10.0" />
                                       </GridPane.margin>
                                    </VBox>
                                    <VBox GridPane.columnIndex="1">
                                       <children>
                                          <Label styleClass="stat-label" text="Llamadas" />
                                          <Label fx:id="lblFibCalls" styleClass="stat-value" text="--" />
                                       </children>
                                    </VBox>
                                 </children>
                              </GridPane>
                              <Label text="Pasos de ejecucción:" />
                              <ListView fx:id="listStepsFib" prefHeight="200.0" prefWidth="200.0" />
                                    </children>
                                </VBox>
                            </items>
                        </SplitPane>
                    </content>
                </Tab>
                <Tab text="Gráfico">
                    <content>
                        <AnchorPane prefHeight="180.0" prefWidth="200.0">
                            <children>
                                <HBox spacing="20.0" AnchorPane.bottomAnchor="10.0" AnchorPane.leftAnchor="10.0" AnchorPane.rightAnchor="10.0" AnchorPane.topAnchor="10.0">
                                    <children>
                                        <VBox styleClass="panel" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="panel-title" text="Tiempo de ejecución T(n):" />
                                                <BarChart fx:id="chartTime" VBox.vgrow="ALWAYS">
                                                    <xAxis><CategoryAxis label="n" side="BOTTOM" /></xAxis>
                                                    <yAxis><NumberAxis label="Nanosegundos" side="LEFT" /></yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                        <VBox styleClass="panel" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label styleClass="panel-title" text="Número de llamadas recursivas:" />
                                                <BarChart fx:id="chartCalls" VBox.vgrow="ALWAYS">
                                                    <xAxis><CategoryAxis label="n" side="BOTTOM" /></xAxis>
                                                    <yAxis><NumberAxis label="Cantidad" side="LEFT" /></yAxis>
                                                </BarChart>
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>
            </tabs>
        </TabPane>
    </center>
</BorderPane>
